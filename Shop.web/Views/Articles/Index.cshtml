@model IReadOnlyList<Shop.Domain.Entities.Article>
@{
    Layout = null;
    ViewData["Title"] = "مقالات";
}
<!DOCTYPE html>
<html lang="fa-IR" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="~/css/article.css">
    <title>مقالات</title>
</head>
<body>
    <section class="container">
        <div class="breadcrumb-Container">
            <nav class="breadcrumb">
                <a asp-controller="Home" asp-action="Index">خانه</a> ›
                <span>مقالات</span>
            </nav>
        </div>

        <header class="header-sec" style="margin: 2rem 0;">
            <h1>مقالات</h1>
        </header>

        <section class="container-fluid">
            @if (!Model.Any())
            {
                <p>مقاله‌ای یافت نشد.</p>
            }
            else
            {
                @foreach (var article in Model)
                {
                    <article style="margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid #eee;">
                        <a asp-action="Details" asp-route-id="@article.Slug">
                            @if (!string.IsNullOrEmpty(article.ImageUrl))
                            {
                                <img src="@article.ImageUrl" alt="@article.Title" style="max-width:200px;border-radius:8px;margin-bottom:.5rem;">
                            }
                            <h2>@article.Title</h2>
                        </a>
                        @if (!string.IsNullOrEmpty(article.Summary))
                        {
                            <p>@article.Summary</p>
                        }
                        <small style="color:#888;">@(article.PublishedAt?.ToString("yyyy/MM/dd") ?? article.CreatedAt.ToString("yyyy/MM/dd"))</small>
                    </article>
                }
            }
        </section>
    </section>
</body>
</html>
