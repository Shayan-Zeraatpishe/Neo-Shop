@model CartSummaryDto
@{
    Layout = null;
    ViewData["Title"] = "سبد خرید";
}
<!DOCTYPE html>
<html lang="fa-IR" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="~/css/cart.css">
    <title>سبد خرید</title>
</head>
<body>
    <section class="container">
        <section class="Steps">
            <div class="box">
                <div class="tick img arrow-left">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><path fill="#ffffff" d="M24 48C10.7 48 0 58.7 0 72C0 85.3 10.7 96 24 96L69.3 96C73.2 96 76.5 98.8 77.2 102.6L129.3 388.9C135.5 423.1 165.3 448 200.1 448L456 448C469.3 448 480 437.3 480 424C480 410.7 469.3 400 456 400L200.1 400C188.5 400 178.6 391.7 176.5 380.3L171.4 352L475 352C505.8 352 532.2 330.1 537.9 299.8L568.9 133.9C572.6 114.2 557.5 96 537.4 96L124.7 96L124.3 94C119.5 67.4 96.3 48 69.2 48L24 48z"/></svg>
                </div>
                <span>سبد خرید</span>
            </div>
            <div class="box">
                <div class="not-tick img arrow-left">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><path fill="#ffffff" d="M0 72C0 58.7 10.7 48 24 48L69.3 48C96.4 48 119.6 67.4 124.4 94L124.8 96L537.5 96C557.5 96 572.6 114.2 568.9 133.9L537.8 299.8C532.1 330.1 505.7 352 474.9 352L171.3 352L176.4 380.3C178.5 391.7 188.4 400 200 400L456 400C469.3 400 480 410.7 480 424C480 437.3 469.3 448 456 448L200.1 448C165.3 448 135.5 423.1 129.3 388.9L77.2 102.6C76.5 98.8 73.2 96 69.3 96L24 96C10.7 96 0 85.3 0 72z"/></svg>
                </div>
                <span>تسویه حساب</span>
            </div>
            <div class="box">
                <div class="not-tick img">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><path fill="#ffffff" d="M142 66.2C150.5 62.3 160.5 63.7 167.6 69.8L208 104.4L248.4 69.8C257.4 62.1 270.7 62.1 279.6 69.8L320 104.4L360.4 69.8C369.4 62.1 382.6 62.1 391.6 69.8L432 104.4L472.4 69.8C479.5 63.7 489.5 62.3 498 66.2C506.5 70.1 512 78.6 512 88L512 552C512 561.4 506.5 569.9 498 573.8C489.5 577.7 479.5 576.3 472.4 570.2L432 535.6L391.6 570.2C382.6 577.9 369.4 577.9 360.4 570.2L320 535.6L279.6 570.2C270.6 577.9 257.3 577.9 248.4 570.2L208 535.6L167.6 570.2C160.5 576.3 150.5 577.7 142 573.8C133.5 569.9 128 561.4 128 552L128 88C128 78.6 133.5 70.1 142 66.2z"/></svg>
                </div>
                <span>فاکتور</span>
            </div>
        </section>

        <section class="container-fluid">
            <section class="sec-right">
                @foreach (var item in Model.Items)
                {
                    <section class="card">
                        <section class="card-thumnail">
                            <a asp-controller="Products" asp-action="Details" asp-route-slug="@item.Slug">
                                <img src="@(item.ImageUrl ?? "/images/products/mo.png")" alt="@item.ProductName">
                            </a>
                        </section>
                        <section class="card-body">
                            <div class="card-title">
                                <a asp-controller="Products" asp-action="Details" asp-route-slug="@item.Slug">
                                    <h2>@item.ProductName</h2>
                                </a>
                            </div>
                            <div class="card-buttons">
                                <form asp-action="Update" method="post" class="count">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <button type="submit" name="quantity" value="@(item.Quantity + 1)" class="plus">+</button>
                                    <input type="number" value="@item.Quantity" min="1" readonly>
                                    <button type="submit" name="quantity" value="@(item.Quantity - 1)" class="minus">-</button>
                                </form>
                                <div class="amount-box">
                                    @if (item.OriginalPrice.HasValue)
                                    {
                                        <span class="discount-lable">@item.OriginalPrice.Value.ToString("N0")</span>
                                    }
                                    <span class="lable">@item.UnitPrice.ToString("N0")</span>
                                    <span>تومن</span>
                                </div>
                            </div>
                        </section>
                        <section class="remove-cart">
                            <form asp-action="Remove" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button type="submit" class="remove">حذف از سبد خرید</button>
                            </form>
                        </section>
                    </section>
                }
            </section>

            <section class="sec-left">
                <section class="box-details">
                    <section class="header">
                        <span>کل سبد خرید</span>
                        <div>
                            <span>@Model.SubTotal.ToString("N0")</span>
                            <span>تومان</span>
                        </div>
                    </section>
                    <section class="btn-pay">
                        <a asp-controller="Checkout" asp-action="Index">ادامه جهت تسویه حساب</a>
                    </section>
                </section>
            </section>
        </section>
    </section>
    <script src="~/js/cart.js"></script>
</body>
</html>
