@model ProfileViewModel
@{
    Layout = null;
    ViewData["Title"] = "پروفایل کاربری";
}
<!DOCTYPE html>
<html lang="fa-IR" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="~/css/profileedit.css">
    <title>پروفایل کاربری</title>
</head>
<body>


    <section class="profile-edit-container">

        <header class="header-account">
            <h1>ویرایش پروفایل</h1>
        </header>

        @if (TempData["Success"] != null)
        {
            <div class="alert-success">
                @TempData["Success"]
            </div>
        }

        <form asp-action="Index" method="post" class="profile-form">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="FullName"></label>
                <input asp-for="FullName" class="input" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="input" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="PhoneNumber"></label>
                <input asp-for="PhoneNumber" class="input" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>

            <div class="action-buttons">
                <button type="submit" class="btn btn-success">
                    ذخیره تغییرات
                </button>

                <a asp-controller="Account"
                   asp-action="Index"
                   class="btn btn-secondary">
                    بازگشت
                </a>
            </div>

        </form>

    </section>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>
