@model Shop.Domain.Entities.Order
@{
    Layout = null;
    ViewData["Title"] = "فاکتور";
}
<!DOCTYPE html>
<html lang="fa-IR" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="~/css/invoice.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/style.css">
    <title>فاکتور @Model.OrderNumber</title>
</head>
<body>

    <partial name="_partialheader" />

    <section class="container">
        <section class="Steps">
            <div class="box"><div class="tick img arrow-left red"></div><span>سبد خرید</span></div>
            <div class="box"><div class="tick img arrow-left red"></div><span>تسویه حساب</span></div>
            <div class="box"><div class="tick img"></div><span>فاکتور</span></div>
        </section>

        <div class="header">
            <h1>متشکریم، سفارش شما دریافت شد.</h1>
            @if (TempData["PaymentRef"] != null)
            {
                <p>کد پیگیری پرداخت: @TempData["PaymentRef"]</p>
            }
        </div>

        <div class="invoice-details">
            <div class="box">
                <span>شماره سفارش:</span>
                <span>@Model.OrderNumber</span>
            </div>
            <div class="box">
                <span>تاریخ:</span>
                <span>@Model.CreatedAt.ToString("yyyy/MM/dd HH:mm")</span>
            </div>
            <div class="box">
                <span>مبلغ کل:</span>
                <span>@Model.TotalAmount.ToString("N0") تومان</span>
            </div>
        </div>

        <table style="width:100%;margin-top:2rem;border-collapse:collapse;">
            <tr style="background:#f5f5f5;">
                <th style="padding:.5rem;border:1px solid #ddd;">محصول</th>
                <th style="padding:.5rem;border:1px solid #ddd;">تعداد</th>
                <th style="padding:.5rem;border:1px solid #ddd;">قیمت</th>
            </tr>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td style="padding:.5rem;border:1px solid #ddd;">@item.ProductName</td>
                    <td style="padding:.5rem;border:1px solid #ddd;">@item.Quantity</td>
                    <td style="padding:.5rem;border:1px solid #ddd;">@item.TotalPrice.ToString("N0") تومان</td>
                </tr>
            }
        </table>
    </section>


    <partial name="_partialfooter" />

</body>
</html>
