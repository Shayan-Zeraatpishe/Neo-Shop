@model ProductDetailsViewModel
@{
    Layout = null;
    var product = Model.Product;
    var price = product.DiscountPrice ?? product.Price;
    ViewData["Title"] = product.Name;

    var galleryImages = new List<string>();
    if (!string.IsNullOrWhiteSpace(product.MainImageUrl))
        galleryImages.Add(product.MainImageUrl);
    foreach (var img in product.Images.OrderBy(i => i.DisplayOrder))
    {
        if (!string.IsNullOrWhiteSpace(img.ImageUrl) && !galleryImages.Contains(img.ImageUrl))
            galleryImages.Add(img.ImageUrl);
    }
    if (galleryImages.Count == 0)
        galleryImages.Add("/images/products/mo.png");

    var specLines = string.IsNullOrWhiteSpace(product.Specifications)
        ? Array.Empty<string>()
        : product.Specifications.Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries);
}
<!DOCTYPE html>
<html lang="fa-IR" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="~/css/style.css">
    <link rel="stylesheet" href="~/css/product.css">
    <title>@(ViewData["Title"])</title>
</head>
<body>

    <partial name="_partialheader" />

    <section class="container">

        <div class="breadcrumb-Container">
            <nav class="breadcrumb">
                <a asp-controller="Home" asp-action="Index">خانه</a> ›
                <a asp-controller="Shop" asp-action="Index">فروشگاه</a> ›
                <span>@product.Name</span>
            </nav>
        </div>

        <section class="product-1">

            <section class="sec-right">

                <div class="container-img" dir="ltr">
                    <div class="gallery">
                        <div class="gallery-preview">
                            <div class="slider-track">
                                @foreach (var imageUrl in galleryImages)
                                {
                                    <img src="@imageUrl" alt="@product.Name" class="slide">
                                }
                            </div>
                        </div>
                        <div class="gallery-thumbnails">
                            @foreach (var imageUrl in galleryImages)
                            {
                                <img src="@imageUrl" alt="@product.Name" class="thumbnail">
                            }
                        </div>
                    </div>

                    <div id="image-modal" class="modal">
                        <span class="close">&times;</span>
                        <img class="modal-content" id="modal-img">
                    </div>
                </div>

                <section class="body-product">
                    <header>
                        <h1>@product.Name</h1>
                        @if (!string.IsNullOrWhiteSpace(product.ShortDescription))
                        {
                            <h4>@product.ShortDescription</h4>
                        }
                        <hr>
                    </header>

                    <section class="header-details">
                        <span>برند : @(product.Brand ?? "-")</span>
                        <span>دسته : @(product.Category?.Name ?? "-")</span>
                        <span>موجودی : @product.Stock</span>
                    </section>

                    @if (specLines.Length > 0)
                    {
                        <section class="advanced-details">
                            @foreach (var line in specLines.Take(3))
                            {
                                var parts = line.Split(':', 2);
                                <div>
                                    <span class="header-d">@(parts.Length > 1 ? parts[0].Trim() : "مشخصه")</span>
                                    <span class="body-d">@(parts.Length > 1 ? parts[1].Trim() : line.Trim())</span>
                                </div>
                            }
                        </section>
                    }
                </section>

            </section>

            <section class="sec-left">
                <section class="additional">
                    <p>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
                            <path fill="#222222" d="M320 576C178.6 576 64 461.4 64 320C64 178.6 178.6 64 320 64C461.4 64 576 178.6 576 320C576 461.4 461.4 576 320 576zM438 209.7C427.3 201.9 412.3 204.3 404.5 215L285.1 379.2L233 327.1C223.6 317.7 208.4 317.7 199.1 327.1C189.8 336.5 189.7 351.7 199.1 361L271.1 433C276.1 438 282.9 440.5 289.9 440C296.9 439.5 303.3 435.9 307.4 430.2L443.3 243.2C451.1 232.5 448.7 217.5 438 209.7z" />
                        </svg>
                        تضمین بهترین قیمت
                    </p>
                    <p>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
                            <path fill="#222222" d="M271.2 56C265.1 49.8 256.2 47.3 247.8 49.6C239.4 51.9 232.9 58.4 230.8 66.8L215.5 127C214.4 131.4 209.9 134 205.6 132.7L145.8 115.9C137.4 113.5 128.4 115.9 122.3 122C116.2 128.1 113.8 137.1 116.2 145.5L133.1 205.3C134.3 209.6 131.7 214.1 127.4 215.2L67.1 230.5C58.7 232.6 52.1 239.2 49.8 247.6C47.5 256 50 264.9 56.2 271L100.7 314.3C103.9 317.4 103.9 322.6 100.7 325.8L56.3 369.1C50.1 375.2 47.6 384.1 49.9 392.5C52.2 400.9 58.8 407.4 67.2 409.6L127.4 424.9C131.8 426 134.4 430.5 133.1 434.8L116.2 494.5C113.8 502.9 116.2 511.9 122.3 518C128.4 524.1 137.4 526.5 145.8 524.1L205.6 507.2C209.9 506 214.4 508.6 215.5 512.9L230.8 573.1C232.9 581.5 239.5 588.1 247.9 590.4C256.3 592.7 265.2 590.2 271.3 584L314.6 539.5C317.7 536.3 322.9 536.3 326.1 539.5L369.3 584C375.4 590.2 384.3 592.7 392.7 590.4C401.1 588.1 407.6 581.5 409.8 573.1L425.1 513C426.2 508.6 430.7 506 435 507.3L494.8 524.2C503.2 526.6 512.2 524.2 518.3 518.1C524.4 512 526.8 503 524.4 494.6L507.5 434.8C506.3 430.5 508.9 426 513.2 424.9L573.4 409.6C581.8 407.5 588.4 400.9 590.7 392.5C593 384.1 590.5 375.1 584.3 369.1L539.8 325.8C536.6 322.7 536.6 317.5 539.8 314.3L584.3 271C590.5 264.9 593 256 590.7 247.6C588.4 239.2 581.8 232.7 573.4 230.5L513.2 215.2C508.8 214.1 506.2 209.6 507.5 205.3L524.4 145.5C526.8 137.1 524.4 128.1 518.3 122C512.2 115.9 503.2 113.5 494.8 115.9L435 132.8C430.7 134 426.2 131.4 425.1 127.1L409.8 66.8C407.7 58.4 401.1 51.8 392.7 49.5C384.3 47.2 375.4 49.7 369.3 55.9L326 100.5C322.9 103.7 317.7 103.7 314.5 100.5L271.2 56z" />
                        </svg>
                        @(product.Stock > 0 ? "موجود در انبار" : "ناموجود")
                    </p>
                    <p>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
                            <path fill="#222222" d="M32 206.1L32 544C32 561.7 46.3 576 64 576C81.7 576 96 561.7 96 544L96 304C96 286.3 110.3 272 128 272L512 272C529.7 272 544 286.3 544 304L544 544C544 561.7 558.3 576 576 576C593.7 576 608 561.7 608 544L608 206.1C608 178.6 590.4 154.1 564.2 145.4L335.2 69.1C325.3 65.8 314.7 65.8 304.8 69.1L75.8 145.4C49.6 154.1 32 178.6 32 206.1zM496 320L144 320L144 384L496 384L496 320zM144 480L496 480L496 416L144 416L144 480zM496 512L144 512L144 576L496 576L496 512z" />
                        </svg>
                        ارسال در 3 روز کاری
                    </p>
                </section>

                <hr>

                <div class="amount">
                    @if (product.DiscountPrice.HasValue && product.DiscountPrice < product.Price)
                    {
                        <span style="text-decoration:line-through;color:#999;">@product.Price.ToString("N0")</span>
                    }
                    <span>@price.ToString("N0")</span>
                    <span>تومان</span>
                </div>

                @if (product.Stock > 0)
                {
                    <form asp-controller="Orders" asp-action="BuyNow" asp-route-productId="@product.Id" method="post" class="btn-pay">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-pay">خرید محصول</button>
                    </form>
                }
            </section>

        </section>

        <section class="container-fluid">

            <section class="row">
                <div class="tab-menu">
                    <ul class="tab-btn">
                        <li class="desctiption" id="desctiption">توضیحات</li>
                        <li class="full-description" id="full-description">توضیحات تکمیلی</li>
                        <li class="comments" id="comments">نظرات (@Model.Comments.Count)</li>
                    </ul>
                </div>
            </section>

            <section class="container-description" id="row1">
                <h2>معرفی محصول</h2>
                <hr>
                @if (!string.IsNullOrWhiteSpace(product.Description))
                {
                    @Html.Raw(product.Description)
                }
                else if (!string.IsNullOrWhiteSpace(product.ShortDescription))
                {
                    <p>@product.ShortDescription</p>
                }
                else
                {
                    <p>توضیحاتی برای این محصول ثبت نشده است.</p>
                }
            </section>

            <section class="container-full-description" id="row2">
                <h2>مشخصات محصول</h2>
                <hr>
                @if (specLines.Length > 0)
                {
                    @foreach (var line in specLines)
                    {
                        var parts = line.Split(':', 2);
                        <div class="property-item">
                            <span>@(parts.Length > 1 ? parts[0].Trim() : "مشخصه")</span>
                            <p>@(parts.Length > 1 ? parts[1].Trim() : line.Trim())</p>
                        </div>
                    }
                }
                else
                {
                    <p>مشخصات فنی برای این محصول ثبت نشده است.</p>
                }
            </section>

            <section class="comment" id="row3">
                <header class="header-main">
                    <h3>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
                            <path d="M576 304C576 436.5 461.4 544 320 544C282.9 544 247.7 536.6 215.9 523.3L97.5 574.1C88.1 578.1 77.3 575.8 70.4 568.3C63.5 560.8 62 549.8 66.8 540.8L115.6 448.6C83.2 408.3 64 358.3 64 304C64 171.5 178.6 64 320 64C461.4 64 576 171.5 576 304z" />
                        </svg>
                        دیدگاهتان را بنویسید
                    </h3>
                    <p>نشانی ایمیل شما منتشر نخواهد شد. بخش‌های موردنیاز علامت‌گذاری شده‌اند *</p>
                </header>

                @if (TempData["CommentSuccess"] != null)
                {
                    <p style="color:green;margin:1rem 0;">@TempData["CommentSuccess"]</p>
                }

                <form asp-action="AddComment" asp-controller="Products" method="post" class="comment-box">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="NewComment.ProductId" />
                    <input type="hidden" asp-for="NewComment.ProductSlug" />
                    <div asp-validation-summary="ModelOnly" style="color:red;margin-bottom:1rem;"></div>

                    <div class="col-1">
                        <label asp-for="NewComment.Content">دیدگاه *</label>
                        <textarea asp-for="NewComment.Content" id="comment"></textarea>
                        <span asp-validation-for="NewComment.Content" style="color:red;"></span>
                    </div>
                    <div class="col-2">
                        <div class="row-1">
                            <label asp-for="NewComment.AuthorName">نام *</label>
                            <input type="text" asp-for="NewComment.AuthorName" id="name">
                            <span asp-validation-for="NewComment.AuthorName" style="color:red;"></span>
                        </div>
                        <div class="row-2">
                            <label asp-for="NewComment.AuthorEmail">ایمیل *</label>
                            <input type="email" asp-for="NewComment.AuthorEmail" id="email">
                            <span asp-validation-for="NewComment.AuthorEmail" style="color:red;"></span>
                        </div>
                    </div>
                    <div class="col-3">
                        <input type="submit" value="فرستادن دیدگاه">
                    </div>

                    <div class="col-4">
                        @if (!Model.Comments.Any())
                        {
                            <p>هنوز دیدگاهی برای این محصول ثبت نشده است.</p>
                        }
                        @foreach (var comment in Model.Comments)
                        {
                            <section class="container-comment">
                                <header class="header-comment">
                                    <img src="~/images/articles/profile.jpg" alt="profile">
                                    <span class="username">@comment.AuthorName</span>
                                    <span class="comment-date" style="font-size:12px;color:#888;">@comment.CreatedAtUtc.ToLocalTime().ToString("yyyy/MM/dd")</span>
                                </header>
                                <section class="body-comment">
                                    <p>@comment.Content</p>
                                    @if (!string.IsNullOrWhiteSpace(comment.AdminReply))
                                    {
                                        <div style="margin-top:.5rem;padding:.5rem;background:#f5f5f5;border-radius:4px;">
                                            <strong>پاسخ فروشگاه:</strong>
                                            <p>@comment.AdminReply</p>
                                        </div>
                                    }
                                </section>
                            </section>
                        }
                    </div>
                </form>
            </section>
        </section>

    </section>

    <partial name="_partialfooter" />

    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/gallery-img.js"></script>
    <script src="~/js/product.js"></script>
    <script src="~/js/counter.js"></script>

</body>
</html>
