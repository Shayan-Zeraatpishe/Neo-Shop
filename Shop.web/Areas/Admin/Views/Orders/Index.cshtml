@model Shop.web.Areas.Admin.ViewModels.Orders.AdminOrdersIndexViewModel
@using Shop.web.Helpers
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="fa-IR" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="~/admin/css/admin.css">
    <link rel="stylesheet" href="~/admin/css/listorder.css">

    <link rel="stylesheet" href="~/admin/js/JalaliDatePicker-main/dist/jalalidatepicker.min.css">
    <link rel="stylesheet" href="~/admin/css/selector-new.css">

    <title>@(ViewData["Title"] ?? "پنل ادمین")</title>
</head>
<body>


    <partial name="_Headertopadmin" />

    <section class="container-fluid">

        <div class="container-dark" onclick="CloseModalbtn()"></div>

        <partial name="_listnav" />

        <section class="container-body">
            <header class="header-sec">
                <h1>لیست سفارش ها</h1>
            </header>

            @{
                var fromDate = Model.Filter.FromDate?.ToString("yyyy-MM-dd");
                var toDate = Model.Filter.ToDate?.ToString("yyyy-MM-dd");
                var minTotal = Model.Filter.MinTotalAmount?.ToString(System.Globalization.CultureInfo.InvariantCulture);
                var maxTotal = Model.Filter.MaxTotalAmount?.ToString(System.Globalization.CultureInfo.InvariantCulture);
            }

            <div class="continer-orders">

                <section class="filter">
                    <form method="get" asp-action="Index" asp-controller="Orders" asp-area="Admin">
                        <input type="number" name="OrderId" class="inp-number" placeholder="شناسه سفارش" value="@Model.Filter.OrderId" />

                        <select name="Status" class="select-order">
                            <option value="">همه وضعیت ها</option>
                            @foreach (var st in Enum.GetValues<Shop.Domain.Enums.OrderStatus>())
                            {
                                <option value="@( (int)st )" selected="@(Model.Filter.Status == st)">
                                    @OrderStatusHelper.GetPersianLabel(st)
                                </option>
                            }
                        </select>

                        <select name="PaymentStatus" class="select-order">
                            <option value="">همه پرداخت ها</option>
                            <option value="0" selected="@(Model.Filter.PaymentStatus == Shop.Domain.Enums.PaymentStatus.Unpaid)">پرداخت نشده</option>
                            <option value="1" selected="@(Model.Filter.PaymentStatus == Shop.Domain.Enums.PaymentStatus.Paid)">پرداخت شده</option>
                        </select>

                        <input type="date" name="FromDate" class="inp-date" value="@fromDate" />
                        <input type="date" name="ToDate" class="inp-date" value="@toDate" />

                        <input type="text" name="MinTotalAmount" class="inp-number" placeholder="حداقل مبلغ" value="@minTotal" />
                        <input type="text" name="MaxTotalAmount" class="inp-number" placeholder="حداکثر مبلغ" value="@maxTotal" />

                        <input type="hidden" name="PageSize" value="@Model.Filter.PageSize" />
                        <input type="hidden" name="SortBy" value="@Model.Filter.SortBy" />
                        <input type="hidden" name="SortDescending" value="@Model.Filter.SortDescending" />

                        <button type="submit" class="btn btn-fillter">اعمال فیلتر</button>
                    </form>
                </section>

                <section class="orders-table">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>شناسه</th>
                                <th>مشتری</th>
                                <th>وضعیت</th>
                                <th>پرداخت</th>
                                <th>تاریخ</th>
                                <th>مبلغ</th>
                                <th>عملیات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Orders.Count == 0)
                            {
                                <tr>
                                    <td colspan="7">سفارشی یافت نشد.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var o in Model.Orders)
                                {
                                    <tr>
                                        <td>@o.OrderNumber</td>
                                        <td>@o.FullName</td>
                                        <td>@OrderStatusHelper.GetPersianLabel(o.Status)</td>
                                        <td>@(o.PaymentStatus == Shop.Domain.Enums.PaymentStatus.Paid ? "پرداخت شده" : "پرداخت نشده")</td>
                                        <td>@o.CreatedAtUtc.ToString("yyyy/MM/dd")</td>
                                        <td>@o.TotalAmount.ToString("N0")</td>
                                        <td>
                                            <a asp-action="Details" asp-route-id="@o.Id" class="btn btn-primary">جزئیات</a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>

                    @if (Model.TotalPages > 1)
                    {
                        <nav class="pagging">
                            <ul class="list-count">
                                @if (Model.HasPrevious)
                                {
                                    <li>
                                        <a asp-action="Index"
                                           asp-route-OrderId="@Model.Filter.OrderId"
                                           asp-route-Customer="@Model.Filter.Customer"
                                           asp-route-Status="@Model.Filter.Status"
                                           asp-route-PaymentStatus="@Model.Filter.PaymentStatus"
                                           asp-route-FromDate="@fromDate"
                                           asp-route-ToDate="@toDate"
                                           asp-route-MinTotalAmount="@minTotal"
                                           asp-route-MaxTotalAmount="@maxTotal"
                                           asp-route-SortBy="@Model.Filter.SortBy"
                                           asp-route-SortDescending="@Model.Filter.SortDescending"
                                           asp-route-PageSize="@Model.Filter.PageSize"
                                           asp-route-PageNumber="@(Model.PageNumber - 1)">
                                            قبلی
                                        </a>
                                    </li>
                                }

                                @for (int p = 1; p <= Model.TotalPages; p++)
                                {
                                    <li class="@(p == Model.PageNumber ? "active" : null)">
                                        <a asp-action="Index"
                                           asp-route-OrderId="@Model.Filter.OrderId"
                                           asp-route-Customer="@Model.Filter.Customer"
                                           asp-route-Status="@Model.Filter.Status"
                                           asp-route-PaymentStatus="@Model.Filter.PaymentStatus"
                                           asp-route-FromDate="@fromDate"
                                           asp-route-ToDate="@toDate"
                                           asp-route-MinTotalAmount="@minTotal"
                                           asp-route-MaxTotalAmount="@maxTotal"
                                           asp-route-SortBy="@Model.Filter.SortBy"
                                           asp-route-SortDescending="@Model.Filter.SortDescending"
                                           asp-route-PageSize="@Model.Filter.PageSize"
                                           asp-route-PageNumber="@p">
                                            @p
                                        </a>
                                    </li>
                                }

                                @if (Model.HasNext)
                                {
                                    <li>
                                        <a asp-action="Index"
                                           asp-route-OrderId="@Model.Filter.OrderId"
                                           asp-route-Customer="@Model.Filter.Customer"
                                           asp-route-Status="@Model.Filter.Status"
                                           asp-route-PaymentStatus="@Model.Filter.PaymentStatus"
                                           asp-route-FromDate="@fromDate"
                                           asp-route-ToDate="@toDate"
                                           asp-route-MinTotalAmount="@minTotal"
                                           asp-route-MaxTotalAmount="@maxTotal"
                                           asp-route-SortBy="@Model.Filter.SortBy"
                                           asp-route-SortDescending="@Model.Filter.SortDescending"
                                           asp-route-PageSize="@Model.Filter.PageSize"
                                           asp-route-PageNumber="@(Model.PageNumber + 1)">
                                            بعدی
                                        </a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    }
                </section>

                <section class="filter" style="display:none;">

                    <input data-jdp autocomplete="off" class="inp-date" placeholder="از تاریخ ">
                    <input data-jdp autocomplete="off" class="inp-date" placeholder="تا تاریخ">

                    <select name="order-type" class="select-order" id="">
